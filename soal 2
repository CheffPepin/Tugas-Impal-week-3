#include <stdio.h>
#include <stdlib.h>


int main()
{
    int computer_amount, base_fee, add_fee, peripheral;
    char dropoff_pickup, office_hours;

    printf("Masukkan jumlah komputer yang ingin di servis\n");
    scanf("%d", &computer_amount);

    printf("berapa device tambahan? (jika tidak ada ketik 0)\n");
    scanf("%d", &peripheral);

    printf("Apakah anda bersedia drop off dan pick up?(Y/T)\n");
    scanf(" %c", &dropoff_pickup);

    printf("Apakah sedang di luar jam kerja?(Y/T)\n");
    scanf(" %c", &office_hours);

    if(computer_amount == 1 || computer_amount == 2){
        base_fee = 50;
        add_fee = 0;
    } else if(computer_amount >= 3 && computer_amount <= 10){
        base_fee = 100;
    } else if(computer_amount > 10){
        base_fee = 500;
    }

    if(computer_amount >= 3 && peripheral > 0){
        add_fee = peripheral * 10;
    }

    if(office_hours == 'Y'){
        base_fee = base_fee*2;
    }

    if(dropoff_pickup == 'Y'){
        base_fee = base_fee/2;
    }

    printf("total biaya: %d", base_fee + add_fee);

}
